        <mxCell id="qE7uYhavsmvArXDMt-8v-121" parent="1" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;fontSize=10;fontColor=#9E9E9E;" value="─────────────────────────" vertex="1">
          <mxGeometry height="20" width="260" x="3030.470559512868" y="561.4705810546875" as="geometry" />
        </mxCell>
        <mxCell id="qE7uYhavsmvArXDMt-8v-122" parent="1" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=10;fontColor=#424242;" value="&lt;b&gt;ПОТОКИ ДАННЫХ&lt;/b&gt;&lt;br&gt;Жёлтая стрелка: обратная связь&lt;br&gt;Зелёная: проверка OK&lt;br&gt;Пурпурная: вызов агента&lt;br&gt;Синяя: источник → ETL&lt;br&gt;Оранжевая: аналитика → граф" vertex="1">
          <mxGeometry height="90" width="260" x="3030.470559512868" y="591.4705810546875" as="geometry" />
        </mxCell>
        <mxCell id="qE7uYhavsmvArXDMt-8v-123" parent="1" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=10;fontColor=#424242;" value="&lt;b&gt;АРХИТЕКТУРА&lt;/b&gt;&lt;br&gt;Домен: Финансовый анализ акций MOEX&lt;br&gt;Граф знаний: Neo4j (онтология рынка)&lt;br&gt;Граф агентов: LangGraph / CrewAI&lt;br&gt;LLM: GPT-4 / Claude 3.5&lt;br&gt;Vector: Qdrant / Pinecone" vertex="1">
          <mxGeometry height="110" width="260" x="3030.470559512868" y="691.4705810546875" as="geometry" />
        </mxCell>
        <mxCell id="qE7uYhavsmvArXDMt-8v-124" connectable="0" parent="1" style="group" value="" vertex="1">
          <mxGeometry height="300" width="2200" x="650.0005595128678" y="1200.0005810546875" as="geometry" />
        </mxCell>
        <mxCell id="qE7uYhavsmvArXDMt-8v-9" parent="qE7uYhavsmvArXDMt-8v-124" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFEBEE;strokeColor=#C62828;strokeWidth=2;opacity=30;" value="" vertex="1">
          <mxGeometry height="300" width="2200" as="geometry" />
        </mxCell>
        <mxCell id="qE7uYhavsmvArXDMt-8v-10" parent="qE7uYhavsmvArXDMt-8v-124" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;fontSize=16;fontStyle=1;fontColor=#B71C1C;" value="📍 END-TO-END: «Какие акции сектора нефтегаза показали рост выше рынка за последний месяц?»" vertex="1">
          <mxGeometry height="30" width="900" x="10" y="10" as="geometry" />
        </mxCell>
        <mxCell id="qE7uYhavsmvArXDMt-8v-84" parent="qE7uYhavsmvArXDMt-8v-124" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFCDD2;strokeColor=#C62828;fontSize=10;" value="&lt;b&gt;1. Пользователь&lt;/b&gt;&lt;br&gt;Какие акции сектора нефтегаза показали рост выше рынка за последний месяц и какие фундаментальные факторы это объясняют?" vertex="1">
          <mxGeometry height="120" width="200" x="30" y="50" as="geometry" />
        </mxCell>
        <mxCell id="qE7uYhavsmvArXDMt-8v-85" parent="qE7uYhavsmvArXDMt-8v-124" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFCDD2;strokeColor=#C62828;fontSize=10;" value="&lt;b&gt;2. Router&lt;/b&gt;&lt;br&gt;Intent: сравнительный_анализ&lt;br&gt;Entities: [нефтегаз, акции, рост, месяц, фундаментал]&lt;br&gt;Plan: [цены, сектор, метрики]" vertex="1">
          <mxGeometry height="120" width="200" x="280" y="50" as="geometry" />
        </mxCell>
        <mxCell id="qE7uYhavsmvArXDMt-8v-86" parent="qE7uYhavsmvArXDMt-8v-124" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFCDD2;strokeColor=#C62828;fontSize=10;" value="&lt;b&gt;3. Decomposer&lt;/b&gt;&lt;br&gt;Q1: акции MOEXOG за месяц&lt;br&gt;Q2: доходность vs MOEX&lt;br&gt;Q3: P/E, EPS, дивиденды&lt;br&gt;Q4: новости-факторы" vertex="1">
          <mxGeometry height="120" width="200" x="530" y="50" as="geometry" />
        </mxCell>
        <mxCell id="qE7uYhavsmvArXDMt-8v-87" parent="qE7uYhavsmvArXDMt-8v-124" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFCDD2;strokeColor=#C62828;fontSize=9;" value="&lt;b&gt;4. Cypher Agent&lt;/b&gt;&lt;br&gt;MATCH (s:Security)-[:BELONGS_TO]-&gt;(sec:Sector)&lt;br&gt;WHERE sec.name=&#39;Нефтегаз&#39;&lt;br&gt;MATCH (s)-[:HAS_PRICE]-&gt;(p)&lt;br&gt;RETURN s.secid, p.close..." vertex="1">
          <mxGeometry height="120" width="200" x="780" y="50" as="geometry" />
        </mxCell>
        <mxCell id="qE7uYhavsmvArXDMt-8v-88" parent="qE7uYhavsmvArXDMt-8v-124" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFCDD2;strokeColor=#C62828;fontSize=10;" value="&lt;b&gt;5. Subgraph + Vector&lt;/b&gt;&lt;br&gt;Подграф: SNGS, LKOH, ROSN, TATN + соседи&lt;br&gt;Вектор: новости о нефти, ОПЕК+, санкции" vertex="1">
          <mxGeometry height="120" width="200" x="1030" y="50" as="geometry" />
        </mxCell>
        <mxCell id="qE7uYhavsmvArXDMt-8v-89" parent="qE7uYhavsmvArXDMt-8v-124" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFCDD2;strokeColor=#C62828;fontSize=10;" value="&lt;b&gt;6. Synthesizer&lt;/b&gt;&lt;br&gt;Объединение:&lt;br&gt;Граф: цены, метрики&lt;br&gt;Вектор: новости&lt;br&gt;Аналитика: PageRank&lt;br&gt;→ структурированный evidence" vertex="1">
          <mxGeometry height="120" width="200" x="1280" y="50" as="geometry" />
        </mxCell>
        <mxCell id="qE7uYhavsmvArXDMt-8v-90" parent="qE7uYhavsmvArXDMt-8v-124" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFCDD2;strokeColor=#C62828;fontSize=10;" value="&lt;b&gt;7. LLM + Graders&lt;/b&gt;&lt;br&gt;Генерация ответа с цитатами из графа&lt;br&gt;Проверка: факты совпадают с evidence?&lt;br&gt;Оценка: 0.92/1.0" vertex="1">
          <mxGeometry height="120" width="200" x="1530.0000000000002" y="50" as="geometry" />
        </mxCell>
        <mxCell id="qE7uYhavsmvArXDMt-8v-91" parent="qE7uYhavsmvArXDMt-8v-124" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#C8E6C9;strokeColor=#2E7D32;fontSize=10;" value="&lt;b&gt;8. Ответ пользователю&lt;/b&gt;&lt;br&gt;Акции нефтегазового сектора за июнь 2026:&lt;br&gt;LKOH +12.3% (vs MOEX +5.1%) → рост P/E, дивиденды&lt;br&gt;ROSN +8.7% → новые месторождения&lt;br&gt;[источники: граф + новости]" vertex="1">
          <mxGeometry height="120" width="250" x="1780.0000000000002" y="50" as="geometry" />
        </mxCell>
