        <mxCell id="qE7uYhavsmvArXDMt-8v-52" parent="qE7uYhavsmvArXDMt-8v-125" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#CE93D8;strokeColor=#7B1FA2;strokeWidth=3;fontSize=11;" value="&lt;b&gt;Router Agent&lt;/b&gt;&lt;br&gt;(Диспетчер)&lt;br&gt;Классификация запроса →&lt;br&gt;выбор стратегии&lt;br&gt;&lt;br&gt;Вход: user_query&lt;br&gt;Выход: plan + intent" vertex="1">
